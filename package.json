{
  "name": "eslint-plugin-use-client",
  "version": "0.0.1",
  "description": "ESLint rule that enforces the 'use client' directive in files using client-only React features (hooks, use(), createContext, browser APIs, event handlers).",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "use client",
    "react",
    "react-server-components",
    "rsc",
    "next"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czarandy/eslint-plugin-use-client.git"
  },
  "bugs": {
    "url": "https://github.com/czarandy/eslint-plugin-use-client/issues"
  },
  "homepage": "https://github.com/czarandy/eslint-plugin-use-client#readme",
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check:exports": "pnpm build && publint",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.0",
    "@typescript-eslint/utils": "^8.60.0",
    "eslint": "^10.4.0",
    "publint": "^0.3.21",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
